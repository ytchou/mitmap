{
  "dimensions": { "card": { "width": 1080, "height": 1350 } },
  "palette": {
    "terracotta": "#C4693B",
    "green": "#2F5D50",
    "dark": "#1C1C1C",
    "cream": "#FFFDF8",
    "scrimBlack": "#000000",
    "stripDark": "#000000CC",
    "stripGreen": "#1D3D34",
    "stripTerracotta": "#A3542A"
  },
  "colors": {
    "background": "#1C1C1C",
    "text": "#FFFDF8",
    "secondary": "#FFFFFFCC",
    "muted": "#FFFFFF99",
    "accent": "#C4693B"
  },
  "typography": {
    "fontHeading": "'Noto Sans TC', system-ui, -apple-system, sans-serif",
    "fontBody": "'Noto Sans TC', system-ui, -apple-system, sans-serif",
    "googleFontsHref": "https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap",
    "zhFallback": "'Noto Sans TC', 'PingFang TC', sans-serif",
    "align": "left",
    "scale": {
      "wordmarkZh": { "size": "20px", "weight": 700 },
      "wordmarkEn": { "size": "16px", "weight": 400 },
      "tag": { "size": "18px", "weight": 500 },
      "headlineCover": { "size": "62px", "weight": 700, "lineHeight": 1.2 },
      "headlineText": { "size": "52px", "weight": 700, "lineHeight": 1.22 },
      "bigStatement": { "size": "62px", "weight": 700, "lineHeight": 1.2 },
      "prose": { "size": "24px", "weight": 400, "lineHeight": 1.7 },
      "quote": { "size": "26px", "weight": 400, "lineHeight": 1.7 },
      "quoteMark": { "size": "64px", "weight": 700 },
      "bullet": { "size": "22px", "weight": 400, "lineHeight": 1.5 },
      "brandName": { "size": "72px", "weight": 700, "lineHeight": 1.1 },
      "attribution": { "size": "18px", "weight": 400 },
      "footer": { "size": "13px", "weight": 400 },
      "ctaButton": { "size": "24px", "weight": 700 }
    }
  },
  "brand": {
    "wordmarkZh": "島藏",
    "wordmarkEn": "Formoria",
    "logo": null
  },
  "background": {
    "defaults": { "type": "image" },
    "scrim": {
      "cover": [[0, 0], [0.30, 0.40], [1, 0.80]],
      "bullets": [[0, 0.20], [0.35, 0.47], [1, 0.85]],
      "quote": [[0, 0.33], [0.40, 0.60], [1, 0.90]],
      "brandHighlight": [[0, 0], [0.45, 0], [1, 0.80]]
    }
  },
  "accentRules": {
    "image": { "tagBorder": "#C4693B", "tagText": "#C4693B", "ruleColor": "#C4693B", "barColor": "#C4693B", "counter": "#C4693B", "strip": "#000000CC", "ctaBtn": { "bg": "#FFFDF8", "text": "#C4693B" } },
    "dark":  { "tagBorder": "#C4693B", "tagText": "#C4693B", "ruleColor": "#C4693B", "barColor": "#C4693B", "counter": "#C4693B", "strip": "#000000CC", "ctaBtn": { "bg": "#FFFDF8", "text": "#C4693B" } },
    "color": {
      "#2F5D50": { "tagBorder": "#FFFFFF66", "tagText": "#FFFDF8", "ruleColor": "#FFFDF8AA", "barColor": "#FFFDF8AA", "counter": "#FFFDF8", "strip": "#1D3D34", "ctaBtn": { "bg": "#FFFDF8", "text": "#2F5D50" } },
      "#C4693B": { "tagBorder": "#FFFFFF40", "tagText": "#FFFDF8", "ruleColor": "#FFFDF8", "barColor": "#FFFFFF40", "counter": "#FFFDF8", "strip": "#A3542A", "ctaBtn": { "bg": "#FFFDF8", "text": "#C4693B" } }
    }
  },
  "cards": { "templateDir": "marketing/cards/templates" }
}
