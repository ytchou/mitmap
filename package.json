{
  "name": "formoria",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "next dev",
    "email:dev": "email dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:favicon": "node scripts/check-favicon-rgba.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "git config core.hooksPath scripts/hooks 2>/dev/null || true",
    "curate": "tsx --env-file=.env.local scripts/curate-brands.ts",
    "backfill-images": "tsx --env-file=.env.local scripts/backfill-brand-images.ts",
    "remove-brand": "tsx --env-file=.env.local scripts/remove-brand.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke-chromium --project=smoke-firefox --project=smoke-webkit",
    "test:e2e:deep": "playwright test --project=deep",
    "test:e2e:perf": "playwright test --project=perf"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@next/third-parties": "^16.2.6",
    "@radix-ui/react-accordion": "^1.2.13",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "adm-zip": "^0.5.17",
    "agentation": "^3.0.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.23.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "react-email": "^6.6.3",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5",
    "vite": ">=8.1.2",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=8.1.2",
      "ws": ">=8.21.0",
      "undici": ">=7.28.0"
    }
  }
}
