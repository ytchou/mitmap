# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used for JSON-LD absolute URLs)
NEXT_PUBLIC_SITE_URL=https://formoria.com

# Admin
ADMIN_EMAILS=your-email@example.com

# Analytics (optional for dev)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry (optional for dev)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Resend (optional for dev/CI)
RESEND_API_KEY= # Resend API key for transactional owner emails; leave unset to no-op email sending

# Google Maps (optional — only for retail location widget)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Cloudflare Turnstile (bot detection on submission form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Feedback pipeline (DEV-801)
# SENTRY_AUTH_TOKEN (above) is reused for health check + feedback sync — org/project auto-discovered from the token
TALLY_WEBHOOK_SIGNING_SECRET=your_tally_signing_secret  # Found in Tally Dashboard → Webhooks

# E2E test accounts (required for pnpm test:e2e)
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=your-admin-password
E2E_USER_EMAIL=testuser@example.com
E2E_USER_PASSWORD=your-user-password
